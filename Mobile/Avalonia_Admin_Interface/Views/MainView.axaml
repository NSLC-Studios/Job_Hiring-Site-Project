<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Avalonia_Admin_Interface.MainView">
          <Grid>
	   <Grid.RowDefinitions>
		   <RowDefinition/>
       </Grid.RowDefinitions>
       <Grid.ColumnDefinitions>
			<ColumnDefinition/>
			<ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
       <TextBox Text="{Binding RemoveByUserId}" Watermark="User ID" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Top"  FontSize="40" />

       <Button Command="{Binding DeleteUser}" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Content="Delete User" FontSize="40"/>

       <ScrollViewer Grid.Column="1" Grid.Row="0">
		   <StackPanel>
			   <ItemsControl ItemsSource="{Binding Users}">
                   <ItemsControl.ItemTemplate>
					   <DataTemplate>
						   <Varible:UserControl1/>
                       </DataTemplate>
                   </ItemsControl.ItemTemplate>
               </ItemsControl>
           </StackPanel>
       </ScrollViewer>
   </Grid>
 
</Window>
