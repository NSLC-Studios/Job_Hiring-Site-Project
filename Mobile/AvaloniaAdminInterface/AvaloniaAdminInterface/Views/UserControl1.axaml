<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="50"
             x:Class="AvaloniaAdminInterface.Views.UserControl1">

    <Grid ColumnDefinitions="*,2*,*,*,*">

        <TextBlock Grid.Column="0" Text="{Binding UserId}" 
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Column="1" Text="{Binding UserName}" 
                   HorizontalAlignment="Left"/>

        <TextBlock Grid.Column="2" Text="{Binding Role}" 
                   HorizontalAlignment="Center"/>

        <Button Grid.Column="3" Content="Expand"
                Command="{Binding ExpandCommand}"/>

        <Button Grid.Column="4" Content="Delete"
                Command="{Binding DeleteThisUser}"/>

    </Grid>
</UserControl>
