<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AvaloniaAdminInterface.App"
             RequestedThemeVariant="Default">

<Application.Styles>
    <FluentTheme />

  
    <Style Selector="Window">
        <Setter Property="Background" Value="#F0F0F0"/> 
    </Style>

    <Style Selector="Border.top-nav">
        <Setter Property="Background" Value="#3b0f2f"/>  
        <Setter Property="BorderBrush" Value="#2a0b22"/>
        <Setter Property="BorderThickness" Value="0 0 1 0"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <Style Selector="TextBlock.top-nav-title">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="Border.ind-panel">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12"/>
    </Style>


    <Style Selector="Button.ind-btn">
        <Setter Property="Background" Value="#3A6EA5"/> 
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#2F5A88"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <Style Selector="Button.ind-btn:pointerover">
        <Setter Property="Background" Value="#4F8BC7"/>
    </Style>

    <Style Selector="Button.ind-btn:pressed">
        <Setter Property="Background" Value="#2F5A88"/>
    </Style>

    <Style Selector="TextBox.ind-input">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#222222"/>
        <Setter Property="BorderBrush" Value="#AAAAAA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="CaretBrush" Value="#000000"/>
        <Setter Property="SelectionBrush" Value="#3A6EA5"/>
    </Style>

    <Style Selector="TextBox.ind-input:focus">
        <Setter Property="BorderBrush" Value="#3A6EA5"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#000000"/>
    </Style>

    <Style Selector="TextBlock:pointerover, TextBlock:focus, TextBlock:pressed">
        <Setter Property="Foreground" Value="#222222"/>
    </Style>

</Application.Styles>




</Application>
